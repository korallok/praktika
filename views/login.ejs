<%- include("partials/head", { title }) %>
  <body class="auth-body">
    <main class="auth-layout">
      <section class="auth-promo">
        <div class="auth-promo-content">
          <span class="eyebrow">FreshMart</span>
          <h1>Информационная система супермаркета</h1>
          <p>
            Система автоматизирует учёт товаров и продаж, уменьшает ошибки в остатках
            и помогает быстро видеть популярные позиции.
          </p>
          <ul class="feature-list">
            <li>Учёт товаров и остатков на складе</li>
            <li>Продажи с автоматическим списанием</li>
            <li>Быстрые отчёты для управления</li>
          </ul>
        </div>
      </section>

      <section class="auth-card-wrap">
        <div class="auth-card">
          <div class="auth-card-header">
            <h2>Вход в систему</h2>
            <p>Используйте учётную запись сотрудника.</p>
          </div>

          <div class="demo-note">
            Тестовый доступ: <strong>admin</strong> / <strong>admin123</strong>
          </div>

          <div id="globalAlert" class="alert-container"></div>

          <form id="authForm" class="form-grid" data-auth-form="login">
            <label class="form-field">
              <span>Логин</span>
              <input type="text" name="username" placeholder="Введите логин" required />
            </label>

            <label class="form-field">
              <span>Пароль</span>
              <input type="password" name="password" placeholder="Введите пароль" required />
            </label>

            <button class="primary-button" type="submit">Войти</button>
          </form>

          <p class="auth-footer-text">
            Нет аккаунта?
            <a href="/register">Зарегистрироваться</a>
          </p>
        </div>
      </section>
    </main>

    <script src="/js/app.js"></script>
    <script src="/js/auth.js"></script>
  </body>
</html>
