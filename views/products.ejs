<%- include("partials/head", { title }) %>
  <body>
    <div class="app-shell">
      <%- include("partials/sidebar", { currentPath, currentUser }) %>

      <main class="main-content">
        <%- include("partials/topbar", { title, currentUser }) %>

        <section class="content-grid wide">
          <article class="panel">
            <div class="panel-header">
              <h3 id="productFormTitle">Добавление товара</h3>
              <button id="cancelEditButton" class="ghost-button hidden" type="button">
                Отменить редактирование
              </button>
            </div>

            <form id="productForm" class="form-grid two-columns">
              <input id="productId" type="hidden" name="productId" />

              <label class="form-field">
                <span>Название товара</span>
                <input id="productName" type="text" name="name" required />
              </label>

              <label class="form-field">
                <span>Категория</span>
                <select id="productCategory" name="categoryId" required></select>
              </label>

              <label class="form-field">
                <span>Цена, ₽</span>
                <input id="productPrice" type="number" name="price" min="0" step="0.01" required />
              </label>

              <label class="form-field">
                <span>Количество на складе</span>
                <input id="productQuantity" type="number" name="quantity" min="0" step="1" required />
              </label>

              <button class="primary-button" type="submit">Сохранить товар</button>
            </form>
          </article>

          <article class="panel">
            <div class="panel-header">
              <h3>Список товаров</h3>
            </div>

            <form id="searchForm" class="toolbar">
              <input
                id="searchInput"
                class="toolbar-input"
                type="search"
                placeholder="Поиск по названию"
              />
              <button class="secondary-button" type="submit">Найти</button>
              <button id="resetSearchButton" class="ghost-button" type="button">Сбросить</button>
            </form>

            <div class="table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Остаток</th>
                    <th>Действия</th>
                  </tr>
                </thead>
                <tbody id="productsTableBody"></tbody>
              </table>
            </div>
          </article>
        </section>
      </main>
    </div>

    <script src="/js/app.js"></script>
    <script src="/js/products.js"></script>
  </body>
</html>
